# Performance Agent Website — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# GitHub Personal Access Token (required for private repo release proxy)
# Create at: https://github.com/settings/tokens → repo scope
GITHUB_TOKEN=

# Admin passphrase for viewing interest form submissions (default: perfagent2026)
ADMIN_PASS=

# Azure Blob Storage (optional — uses local data/ folder if not set)
# When set, all JSON data is stored in the specified blob container
# Authentication uses Managed Identity (DefaultAzureCredential) — no keys needed
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_CONTAINER=
